VERSION_OP_RE = re.compile(r"[<>=].*$")

# Force English field names regardless of system locale.
ENV = {**os.environ, "LC_ALL": "C"}


def run(cmd, tool_hint=None):
    try:
        return subprocess.run(cmd, capture_output=True, text=True, check=False, env=ENV)
    except FileNotFoundError:
        hint = f" ({tool_hint})" if tool_hint else ""
        sys.exit(f"error: '{cmd[0]}' not found{hint} -- this script must run on an Arch Linux machine.")


def strip_version(token: str) -> str:
    """'glibc>=2.38' -> 'glibc'"""
    return VERSION_OP_RE.sub("", token).strip()


def get_installed_packages():
    """Every package installed on this machine right now, any install reason."""
    result = run(["pacman", "-Qq"])
    if result.returncode != 0:
        sys.exit(f"error querying pacman -Qq:\n{result.stderr}")
    return set(result.stdout.split())


def build_group_map():
    """{pkg: set(groups)} from explicitly-installed local packages only."""
    result = run(["pacman", "-Qegq"])
    if result.returncode != 0:
        sys.exit(f"error querying pacman -Qegq:\n{result.stderr}")

    group_map = {}
    for line in result.stdout.splitlines():
        parts = line.split()
        if len(parts) != 2:
            continue
        group, pkg = parts
        group_map.setdefault(pkg, set()).add(group)
    return group_map


def build_provides_map():
    """{virtual_name: set(real_pkg_names)} from every installed package's own
    "Provides" field -- e.g. {"awk": {"gawk"}, "sh": {"bash"}}.

    Parsed from `pacman -Qi` (no target = dump every installed package's
    full info block) field-by-field rather than a single-line grep, so it
    stays correct even if pacman wraps a long Provides list across
    indented continuation lines (field lines start at column 0;
    continuation lines are indented) -- same parsing approach used
    elsewhere in this file for multi-line pacman output.
    """
    result = run(["pacman", "-Qi"])
    if result.returncode != 0:
        sys.exit(f"error querying pacman -Qi:\n{result.stderr}")

    provides_map = {}
    current_pkg = None
    current_field = None

    for line in result.stdout.splitlines():
        if line.strip() == "":
            current_field = None
            continue

        if not line[0].isspace():
            key, _, value = line.partition(":")
            key, value = key.strip(), value.strip()
            current_field = key
            if key == "Name":
                current_pkg = value
            elif key == "Provides" and current_pkg:
                if value and value != "None":
                    for tok in value.split():
                        provides_map.setdefault(strip_version(tok), set()).add(current_pkg)
        else:
            if current_field == "Provides" and current_pkg:
                value = line.strip()
                if value and value != "None":
                    for tok in value.split():
                        provides_map.setdefault(strip_version(tok), set()).add(current_pkg)

    return provides_map


def build_meta_map(metapackages, installed, provides_map):
    """{pkg: set(metapackages)}, filtered to deps actually installed here.

    A declared dependency that isn't a literal installed package name is
    checked against provides_map as a fallback (see VIRTUAL / "PROVIDES"
    DEPENDENCIES in the module docstring) -- if something installed
    provides that virtual name, the real package gets tagged, not the
    virtual name itself.
    """
    reverse = {}
    for metapkg in metapackages:
        result = run(["expac", "-S", "%E", metapkg], tool_hint="install with: sudo pacman -S expac")
        if result.returncode != 0 or not result.stdout.strip():
            print(f"warning: expac returned nothing for '{metapkg}' "
                  f"(unknown package, or sync db needs `sudo pacman -Sy`):\n{result.stderr}",
                  file=sys.stderr)
            continue

        deps = {strip_version(t) for t in result.stdout.split()}
        skipped = set()

        for dep in deps:
            if dep in installed:
                reverse.setdefault(dep, set()).add(metapkg)
            elif dep in provides_map:
                # Virtual name (e.g. "awk") -- tag whichever real,
                # installed package(s) actually provide it (e.g. "gawk").
                for real_pkg in provides_map[dep]:
                    reverse.setdefault(real_pkg, set()).add(metapkg)
            else:
                skipped.add(dep)

        if skipped:
            print(f"  ({metapkg}: {len(skipped)} declared dep(s) not installed here, skipped: "
                  f"{', '.join(sorted(skipped))})", file=sys.stderr)

    return reverse


def parse_tsv(path: Path):
    text = path.read_text(encoding="utf-8")
    lines = text.split("\n")
    if lines and lines[-1] == "":
        lines.pop()
    header, *rows = lines
    return header, [row.split("\t") for row in rows if row.strip()]


def format_list(items):
    return ", ".join(sorted(items))


def main():
    ap = argparse.ArgumentParser(
        description=__doc__, formatter_class=argparse.RawDescriptionHelpFormatter)
    ap.add_argument("input", type=Path, help="input TSV file")
    ap.add_argument("-o", "--output", type=Path,
                     help="output TSV path (default: <input-stem>.updated.tsv)")
    ap.add_argument("--in-place", action="store_true",
                     help="overwrite the input file directly instead of writing a new one")
    ap.add_argument("--metapackages", default=",".join(DEFAULT_METAPACKAGES),
                     help="comma-separated metapackage names to check membership against "
                          f"(default: {','.join(DEFAULT_METAPACKAGES)})")
    ap.add_argument("--quiet", action="store_true",
                     help="only print the final summary, not every individual change")
    args = ap.parse_args()

    metapackages = [m.strip() for m in args.metapackages.split(",") if m.strip()]

    if args.in_place:
        out_path = args.input
    else:
        out_path = args.output or args.input.with_name(args.input.stem + ".updated.tsv")

    print("Reading locally installed packages (pacman -Qq)...", file=sys.stderr)
    installed = get_installed_packages()

    print("Reading explicitly-installed groups (pacman -Qegq)...", file=sys.stderr)
    group_map = build_group_map()

    print("Reading virtual package names (pacman -Qi Provides)...", file=sys.stderr)
    provides_map = build_provides_map()

    print("Reading metapackage dependencies (expac -S %E)...", file=sys.stderr)
    meta_map = build_meta_map(metapackages, installed, provides_map)

    header, rows = parse_tsv(args.input)

    changed = 0
    not_installed = []
    out_lines = [header]

    for row in rows:
        if len(row) < 4:
            print(f"warning: skipping malformed row (expected 4 columns): {row!r}", file=sys.stderr)
            out_lines.append("\t".join(row))
            continue

        name, old_meta, old_groups, purpose = row[0], row[1], row[2], row[3]

        if name not in installed:
            # No reliable local data -- leave this row exactly as-is.
            not_installed.append(name)
            out_lines.append("\t".join(row))
            continue

        new_meta = format_list(meta_map.get(name, set()))
        new_groups = format_list(group_map.get(name, set()))

        if new_meta != old_meta or new_groups != old_groups:
            changed += 1
            if not args.quiet:
                print(f"  {name}:", file=sys.stderr)
                if new_meta != old_meta:
                    print(f"    meta:   {old_meta!r:30} -> {new_meta!r}", file=sys.stderr)
                if new_groups != old_groups:
                    print(f"    groups: {old_groups!r:30} -> {new_groups!r}", file=sys.stderr)

        out_lines.append("\t".join([name, new_meta, new_groups, purpose]))

    out_path.write_text("\n".join(out_lines) + "\n", encoding="utf-8")

    print(f"\n{changed} of {len(rows)} rows changed.", file=sys.stderr)
    print(f"Written to {out_path}", file=sys.stderr)

    if not_installed:
        print(f"\n{len(not_installed)} package(s) in the TSV are not currently installed here "
              f"-- left untouched (no local data to update them from):", file=sys.stderr)
        for name in not_installed:
            print(f"  - {name}", file=sys.stderr)


if __name__ == "__main__":
    main()
